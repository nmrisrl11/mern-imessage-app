{
	"scripts": {
		"format": "biome format --write .",
		"format:check": "biome check",
		"lint": "biome lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7"
	},
    "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
